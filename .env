# MongoDB Connection String
# Get yours from MongoDB Atlas: https://www.mongodb.com/atlas
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/Stockuser?retryWrites=true&w=majority

# Flask Secret Key for session encryption
# Generate a strong random string, e.g.:
# Python: import secrets; print(secrets.token_hex(32))
SECRET_KEY=your-strong-secret-key-here-change-this-in-production

# Optional: Port for local development
PORT=5003
